<!-- result.wxml -->
<view class="container">
  <!-- 结果卡片 -->
  <view class="result-card">
    <!-- 标题 -->
    <text class="title">答题完成！</text>
    
    <!-- 分数展示 -->
    <view class="score-section">
      <text class="score">{{score}}</text>
      <text class="score-label">总分</text>
    </view>

    <!-- 统计数据 -->
    <view class="stats">
      <view class="stat-item">
        <text class="stat-label">用时</text>
        <text class="stat-value">{{time}}秒</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">正确率</text>
        <text class="stat-value">{{accuracy}}%</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">答对题数</text>
        <text class="stat-value">{{correctCount}}/{{totalQuestions}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="btn secondary" bindtap="goHome">返回首页</button>
      <button class="btn primary" bindtap="tryAgain">再试一次</button>
      <button class="btn share" bindtap="shareResult" open-type="share">分享战绩</button>
    </view>

    <!-- 勋章展示（可选） -->
    <view class="medal-section" wx:if="{{medal}}">
      <text class="medal-label">获得勋章</text>
      <view class="medal">
        <text class="medal-icon">🏅</text>
        <text class="medal-name">{{medal}}</text>
      </view>
    </view>
  </view>
</view>