.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
}

.battles-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.battle-card {
  background: #16213e;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  border: 2rpx solid rgba(251, 191, 36, 0.3);
  transition: all 0.3s;
}

.battle-card:active {
  transform: scale(0.98);
}

.battle-card.finished {
  border-color: rgba(122, 122, 140, 0.3);
  opacity: 0.7;
}

.battle-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4ade80;
}

.status-dot.finished {
  background: #7a7a8c;
}

.status-text {
  font-size: 22rpx;
  color: #7a7a8c;
}

.battle-map {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: rgba(15, 52, 96, 0.3);
  border-radius: 12rpx;
}

.map-icon {
  font-size: 32rpx;
}

.map-name {
  font-size: 28rpx;
  color: #fbbf24;
  font-weight: bold;
}

.battle-teams {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.team-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.team-avatar {
  font-size: 48rpx;
}

.team-name {
  font-size: 26rpx;
  color: #eaeaea;
  text-align: center;
}

.team-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #e94560;
}

.vs-divider {
  padding: 0 30rpx;
}

.vs-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #7a7a8c;
}

.battle-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.viewers {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.viewers-icon {
  font-size: 24rpx;
}

.viewers-count {
  font-size: 22rpx;
  color: #7a7a8c;
}

.watch-btn {
  padding: 12rpx 24rpx;
  background: rgba(233, 69, 96, 0.2);
  border-radius: 20rpx;
}

.watch-text {
  font-size: 24rpx;
  color: #e94560;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7a7a8c;
}

.battle-view {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
}

.battle-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #16213e;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(233, 69, 96, 0.2);
  border-radius: 50%;
}

.back-icon {
  font-size: 28rpx;
  color: #e94560;
}

.battle-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #eaeaea;
}

.live-badge {
  padding: 8rpx 16rpx;
  background: #e94560;
  border-radius: 20rpx;
}

.live-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.battle-arena {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #0f3460 0%, #16213e 100%);
}

.arena-map {
  width: 100%;
  height: 600rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 20rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.3);
  position: relative;
  overflow: hidden;
}

.map-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  padding: 20rpx;
}

.grid-item {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(22, 33, 62, 0.5);
  border-radius: 8rpx;
}

.grid-icon {
  font-size: 32rpx;
}

.team-marker {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.team-marker.team1 {
  top: 100rpx;
  left: 100rpx;
}

.team-marker.team2 {
  bottom: 100rpx;
  right: 100rpx;
}

.marker-avatar {
  font-size: 48rpx;
}

.marker-label {
  padding: 6rpx 12rpx;
  background: rgba(233, 69, 96, 0.8);
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #fff;
}

.battle-scoreboard {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #16213e;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.score-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.score-avatar {
  font-size: 40rpx;
}

.score-name {
  font-size: 24rpx;
  color: #eaeaea;
}

.score-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #e94560;
}

.score-divider {
  padding: 0 40rpx;
}

.divider-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #7a7a8c;
}

.battle-danmu {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background: #16213e;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.danmu-list {
  flex: 1;
  max-height: 300rpx;
  overflow-y: auto;
  margin-bottom: 20rpx;
}

.danmu-item {
  padding: 12rpx;
  margin-bottom: 12rpx;
  background: rgba(15, 52, 96, 0.3);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #eaeaea;
  line-height: 1.5;
}

.danmu-user {
  color: #e94560;
  font-weight: bold;
}

.danmu-input {
  display: flex;
  gap: 16rpx;
}

.input-field {
  flex: 1;
  padding: 16rpx 24rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #eaeaea;
  border: 2rpx solid transparent;
}

.input-field:focus {
  border-color: #e94560;
}

.send-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #e94560 0%, #d6354f 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #7a7a8c;
}