.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
}

.form-section {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
}

.form-input {
  padding: 24rpx;
  background: #16213e;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #eaeaea;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #e94560;
}

.avatar-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.avatar-item {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #16213e;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.avatar-item.active {
  border-color: #e94560;
  background: rgba(233, 69, 96, 0.2);
}

.avatar-emoji {
  font-size: 48rpx;
}

.form-textarea {
  min-height: 200rpx;
  padding: 24rpx;
  background: #16213e;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #eaeaea;
  border: 2rpx solid transparent;
}

.form-textarea:focus {
  border-color: #e94560;
}

.slider-container {
  padding: 20rpx 0;
}

.form-slider {
  width: 100%;
}

.roles-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #16213e;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.role-item.active {
  border-color: #e94560;
  background: rgba(233, 69, 96, 0.1);
}

.role-icon {
  font-size: 40rpx;
}

.role-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.role-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
}

.role-desc {
  font-size: 22rpx;
  color: #7a7a8c;
}

.action-section {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}