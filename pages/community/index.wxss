.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
}

.create-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(233, 69, 96, 0.2);
  border-radius: 50%;
}

.create-icon {
  font-size: 28rpx;
}

.tabs {
  display: flex;
  padding: 20rpx 30rpx;
  background: #16213e;
  gap: 20rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(15, 52, 96, 0.3);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: #e94560;
}

.tab-icon {
  font-size: 32rpx;
}

.tab-name {
  font-size: 22rpx;
  color: #eaeaea;
}

.content {
  padding: 30rpx;
}

.posts-list,
.teams-list,
.sandbox-section,
.notes-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-card,
.team-card,
.note-card {
  background: #16213e;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.post-header,
.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid #e94560;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-nickname {
  font-size: 26rpx;
  color: #eaeaea;
  font-weight: bold;
}

.user-rank {
  font-size: 20rpx;
  color: #7a7a8c;
}

.post-time,
.note-time {
  font-size: 22rpx;
  color: #7a7a8c;
}

.post-content,
.note-content {
  margin-bottom: 20rpx;
}

.post-text,
.note-text {
  font-size: 28rpx;
  color: #eaeaea;
  line-height: 1.6;
}

.note-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #e94560;
  margin-bottom: 12rpx;
}

.post-footer,
.note-footer {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.post-action,
.note-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 24rpx;
}

.action-text {
  font-size: 22rpx;
  color: #7a7a8c;
}

.team-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.team-avatar {
  font-size: 48rpx;
}

.team-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.team-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #eaeaea;
}

.team-leader {
  font-size: 22rpx;
  color: #7a7a8c;
}

.team-rank {
  display: flex;
  align-items: center;
}

.rank-badge {
  padding: 8rpx 16rpx;
  background: rgba(233, 69, 96, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #e94560;
  font-weight: bold;
}

.team-stats {
  display: flex;
  gap: 40rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: rgba(15, 52, 96, 0.3);
  border-radius: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #7a7a8c;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
}

.team-footer {
  display: flex;
  justify-content: center;
}

.team-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #e94560 0%, #d6354f 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.team-btn.disabled {
  background: rgba(122, 122, 140, 0.3);
  color: #7a7a8c;
}

.create-team-section,
.create-note-section {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.create-team-btn,
.create-note-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: rgba(233, 69, 96, 0.2);
  border: 2rpx solid #e94560;
  color: #e94560;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.sandbox-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.3);
}

.sandbox-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.sandbox-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
  margin-bottom: 16rpx;
}

.sandbox-desc {
  font-size: 26rpx;
  color: #7a7a8c;
  margin-bottom: 40rpx;
  text-align: center;
}

.sandbox-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #1a1a2e;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7a7a8c;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #7a7a8c;
}