<view class="container">
  <view class="header">
    <text class="header-title">数据管理</text>
  </view>

  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-icon">👥</text>
      <text class="stat-value">{{stats.totalUsers}}</text>
      <text class="stat-label">总用户数</text>
    </view>
    <view class="stat-card">
      <text class="stat-icon">🟢</text>
      <text class="stat-value">{{stats.activeUsers}}</text>
      <text class="stat-label">活跃用户</text>
    </view>
    <view class="stat-card">
      <text class="stat-icon">📝</text>
      <text class="stat-value">{{stats.totalPosts}}</text>
      <text class="stat-label">总动态数</text>
    </view>
    <view class="stat-card">
      <text class="stat-icon">❓</text>
      <text class="stat-value">{{stats.totalQuestions}}</text>
      <text class="stat-label">总答题数</text>
    </view>
  </view>

  <view class="detail-stats">
    <view class="detail-card">
      <text class="detail-label">今日活跃</text>
      <text class="detail-value">{{stats.todayActive}}</text>
    </view>
    <view class="detail-card">
      <text class="detail-label">平均正确率</text>
      <text class="detail-value">{{stats.avgCorrectRate}}%</text>
    </view>
  </view>

  <view class="charts-section">
    <view class="section-header">
      <text class="section-title">数据统计</text>
    </view>

    <view class="chart-card" wx:for="{{charts}}" wx:key="id">
      <view class="chart-header">
        <text class="chart-title">{{item.title}}</text>
      </view>
      <view class="chart-content">
        <view class="chart-bar" wx:for="{{item.data}}" wx:for-item="data" wx:key="label">
          <text class="bar-label">{{data.label}}</text>
          <view class="bar-wrapper">
            <view class="bar-fill" style="width: {{item.type === 'pie' ? (data.value * 3.6) + 'rpx' : (data.value / 100 * 400) + 'rpx'}}"></view>
            <text class="bar-value">{{data.value}}{{item.type === 'pie' ? '%' : ''}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="actions-section">
    <view class="section-header">
      <text class="section-title">数据操作</text>
    </view>

    <view class="action-list">
      <view class="action-item" bindtap="exportData">
        <view class="action-left">
          <text class="action-icon">📊</text>
          <text class="action-name">导出数据</text>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <view class="action-item" bindtap="backupData">
        <view class="action-left">
          <text class="action-icon">💾</text>
          <text class="action-name">数据备份</text>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <view class="action-item" bindtap="cleanData">
        <view class="action-left">
          <text class="action-icon">🧹</text>
          <text class="action-name">数据清理</text>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>
</view>