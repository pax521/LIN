.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
}

.stats-section {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 30rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #16213e;
  border-radius: 16rpx;
  gap: 12rpx;
}

.stat-icon {
  font-size: 40rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #e94560;
}

.stat-label {
  font-size: 22rpx;
  color: #7a7a8c;
}

.detail-stats {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.detail-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
  border-radius: 16rpx;
  gap: 12rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #7a7a8c;
}

.detail-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fbbf24;
}

.charts-section,
.actions-section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #eaeaea;
}

.chart-card {
  background: #16213e;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.chart-header {
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #eaeaea;
}

.chart-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chart-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bar-label {
  width: 120rpx;
  font-size: 22rpx;
  color: #7a7a8c;
  text-align: right;
}

.bar-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bar-fill {
  height: 24rpx;
  background: linear-gradient(90deg, #e94560 0%, #d6354f 100%);
  border-radius: 12rpx;
  transition: width 0.3s;
}

.bar-value {
  font-size: 22rpx;
  color: #eaeaea;
  font-weight: bold;
  min-width: 60rpx;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #16213e;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.action-item:active {
  transform: scale(0.98);
  background: rgba(233, 69, 96, 0.1);
}

.action-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-icon {
  font-size: 36rpx;
}

.action-name {
  font-size: 28rpx;
  color: #eaeaea;
}

.action-arrow {
  font-size: 40rpx;
  color: #7a7a8c;
}