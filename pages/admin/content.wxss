.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
}

.tabs {
  display: flex;
  padding: 20rpx 30rpx;
  background: #16213e;
  gap: 20rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 30rpx;
  background: rgba(15, 52, 96, 0.3);
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: #e94560;
}

.tab-name {
  font-size: 26rpx;
  color: #eaeaea;
  font-weight: bold;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e94560;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

.badge-count {
  font-size: 18rpx;
  color: #fff;
  font-weight: bold;
}

.contents-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.content-card {
  background: #16213e;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid #e94560;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-nickname {
  font-size: 26rpx;
  font-weight: bold;
  color: #eaeaea;
}

.content-time {
  font-size: 20rpx;
  color: #7a7a8c;
}

.content-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(15, 52, 96, 0.3);
  border-radius: 20rpx;
}

.type-icon {
  font-size: 24rpx;
}

.type-text {
  font-size: 22rpx;
  color: #eaeaea;
}

.content-body {
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 26rpx;
  color: #eaeaea;
  line-height: 1.6;
}

.content-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.content-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.action-btn.success {
  background: linear-gradient(135deg, #4ade80 0%, #22c55e 100%);
  color: #1a1a2e;
}

.action-btn.danger {
  background: rgba(233, 69, 96, 0.2);
  border: 2rpx solid #e94560;
  color: #e94560;
}

.view-btn {
  padding: 16rpx 24rpx;
  background: rgba(15, 52, 96, 0.3);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #7a7a8c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7a7a8c;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #7a7a8c;
}