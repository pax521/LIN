.room-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 32rpx;
  color: #ffffff;
}

.room-header {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.room-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-code {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.room-status {
  font-size: 28rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.3);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.players-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.player-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.player-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
}

.vs-badge {
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  margin: 0 20rpx;
}

.waiting-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.waiting-text {
  display: block;
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 40rpx;
}

.room-code-display {
  display: block;
  font-size: 80rpx;
  font-weight: bold;
  color: #667eea;
  letter-spacing: 20rpx;
  margin-bottom: 20rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #999999;
}

.battle-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.round-info {
  text-align: center;
  margin-bottom: 30rpx;
}

.round-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

.question-card {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.question-text {
  font-size: 32rpx;
  color: #333333;
  line-height: 1.6;
}

.options-list {
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  transition: all 0.3s;
}

.option-item.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.option-item.opponent {
  border: 4rpx solid #ff6b6b;
}

.option-label {
  width: 60rpx;
  height: 60rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #667eea;
  margin-right: 20rpx;
}

.option-item.selected .option-label {
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.option-item.selected .option-text {
  color: #ffffff;
}

.opponent-badge {
  position: absolute;
  right: 20rpx;
  font-size: 20rpx;
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.result-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  width: 80%;
}

.result-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.result-score {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #4ade80;
  margin-bottom: 20rpx;
}

.result-total {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.opponent-status {
  display: block;
  font-size: 28rpx;
  color: #667eea;
}

.result-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.result-header {
  margin-bottom: 60rpx;
}

.result-section .result-title {
  font-size: 64rpx;
}

.final-scores {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.score-card {
  flex: 1;
}

.score-label {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.score-value {
  display: block;
  font-size: 80rpx;
  font-weight: bold;
  color: #667eea;
}

.score-divider {
  font-size: 48rpx;
  color: #999999;
  margin: 0 40rpx;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #667eea;
}
