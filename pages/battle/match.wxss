.match-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

.match-header {
  text-align: center;
  padding: 40rpx 0;
}

.match-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.match-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #ffffff;
}

.tab-text {
  font-size: 32rpx;
  color: #ffffff;
}

.tab.active .tab-text {
  color: #667eea;
  font-weight: bold;
}

.match-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.options-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.option {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  transition: all 0.3s;
}

.option.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.option-text {
  font-size: 28rpx;
  color: #333333;
}

.option.active .option-text {
  color: #ffffff;
  font-weight: bold;
}

.room-code-input {
  width: 100%;
  height: 100rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 36rpx;
  letter-spacing: 10rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.create-btn,
.join-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-btn[disabled],
.join-btn[disabled] {
  opacity: 0.6;
}
