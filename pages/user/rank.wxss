.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
}

.tabs {
  display: flex;
  padding: 20rpx 30rpx;
  background: #16213e;
  gap: 20rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 30rpx;
  background: rgba(15, 52, 96, 0.3);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: #e94560;
}

.tab-name {
  font-size: 26rpx;
  color: #eaeaea;
  font-weight: bold;
}

.rankings-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #16213e;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.rank-item.top {
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.1) 0%, rgba(251, 191, 36, 0.1) 100%);
  border-color: rgba(251, 191, 36, 0.3);
}

.rank-item:active {
  transform: scale(0.98);
}

.rank-number {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 50%;
  flex-shrink: 0;
}

.rank-number.top {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
}

.rank-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #eaeaea;
}

.rank-number.top .rank-text {
  color: #1a1a2e;
}

.rank-avatar {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid #e94560;
}

.avatar-emoji {
  font-size: 48rpx;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.rank-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-detail {
  font-size: 22rpx;
  color: #7a7a8c;
}

.rank-points {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  background: rgba(233, 69, 96, 0.1);
  border-radius: 20rpx;
}

.points-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #e94560;
}

.points-label {
  font-size: 20rpx;
  color: #7a7a8c;
}

.rank-change {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 52, 96, 0.3);
  border-radius: 50%;
  flex-shrink: 0;
}

.change-icon {
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7a7a8c;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #7a7a8c;
}