.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #e94560;
}

.user-avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(233, 69, 96, 0.2);
  border-radius: 50%;
  border: 4rpx solid #e94560;
}

.placeholder-icon {
  font-size: 48rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #eaeaea;
}

.user-tip {
  font-size: 22rpx;
  color: #7a7a8c;
}

.user-badges {
  display: flex;
  gap: 12rpx;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  background: rgba(233, 69, 96, 0.2);
  border-radius: 20rpx;
}

.badge-item.vip {
  background: rgba(251, 191, 36, 0.2);
}

.badge-icon {
  font-size: 20rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #eaeaea;
  font-weight: bold;
}

.user-points {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(233, 69, 96, 0.1);
  border-radius: 16rpx;
}

.points-label {
  font-size: 22rpx;
  color: #7a7a8c;
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #e94560;
}

.stats-section {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #16213e;
  border-radius: 16rpx;
  gap: 12rpx;
}

.stat-icon {
  font-size: 40rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #e94560;
}

.stat-label {
  font-size: 22rpx;
  color: #7a7a8c;
}

.medals-preview {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #eaeaea;
}

.section-more {
  font-size: 24rpx;
  color: #7a7a8c;
}

.medals-scroll {
  white-space: nowrap;
}

.medal-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #16213e;
  border-radius: 16rpx;
  margin-right: 20rpx;
  min-width: 140rpx;
}

.medal-item.empty {
  opacity: 0.5;
}

.medal-icon {
  font-size: 48rpx;
}

.medal-name {
  font-size: 22rpx;
  color: #eaeaea;
}

.menu-section {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #16213e;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.menu-item:active {
  transform: scale(0.98);
  background: rgba(233, 69, 96, 0.1);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-name {
  font-size: 28rpx;
  color: #eaeaea;
}

.menu-arrow {
  font-size: 40rpx;
  color: #7a7a8c;
}

.footer {
  display: flex;
  justify-content: center;
  padding: 40rpx 30rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #7a7a8c;
}