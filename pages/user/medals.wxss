.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #eaeaea;
}

.progress-section {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.progress-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.3);
}

.progress-icon {
  font-size: 48rpx;
}

.progress-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fbbf24;
}

.progress-label {
  font-size: 28rpx;
  color: #eaeaea;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #7a7a8c;
}

.medals-list {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medal-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #16213e;
  border-radius: 16rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.3);
  transition: all 0.3s;
}

.medal-card:active {
  transform: scale(0.98);
}

.medal-card.locked {
  border-color: rgba(122, 122, 140, 0.3);
  opacity: 0.6;
}

.medal-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2) 0%, rgba(245, 158, 11, 0.2) 100%);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.medal-icon-wrapper.locked {
  background: rgba(122, 122, 140, 0.2);
}

.medal-icon {
  font-size: 40rpx;
}

.medal-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.medal-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #eaeaea;
}

.medal-desc {
  font-size: 22rpx;
  color: #7a7a8c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.medal-status {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(74, 222, 128, 0.2);
  border-radius: 50%;
  flex-shrink: 0;
}

.medal-card.locked .medal-status {
  background: rgba(122, 122, 140, 0.2);
}

.status-icon {
  font-size: 24rpx;
  color: #4ade80;
}

.medal-card.locked .status-icon {
  color: #7a7a8c;
}